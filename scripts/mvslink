#!/bin/bash
# mvslink - Link-edit HTTPD load modules on MVS
#
# Based on Mike Rayborn's original link JCLs.
# Each module has its own SYSLIB/NCALIB DD layout matching the original.
set -euo pipefail

# --- Load .env (working directory first, then script's repo root) ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
if [[ -f "$PWD/.env" ]]; then
  source "$PWD/.env"
elif [[ -f "$ROOT_DIR/.env" ]]; then
  source "$ROOT_DIR/.env"
fi

# --- Validate required settings ---
: "${MVS_HOST:?MVS_HOST not set (check .env)}"
: "${MVS_PORT:?MVS_PORT not set (check .env)}"
: "${MVS_USER:?MVS_USER not set (check .env)}"
: "${MVS_PASS:?MVS_PASS not set (check .env)}"
: "${HTTPD_SYSLMOD:?HTTPD_SYSLMOD not set (check .env)}"
: "${HTTPD_LOADLIB:?HTTPD_LOADLIB not set (check .env)}"
: "${CRENT_NCALIB:?CRENT_NCALIB not set (check .env)}"
: "${UFS_NCALIB:?UFS_NCALIB not set (check .env)}"
: "${LUA_NCALIB:?LUA_NCALIB not set (check .env)}"
: "${MQTT_NCALIB:?MQTT_NCALIB not set (check .env)}"

JOBCLASS="${MVS_JOBCLASS:-A}"
MSGCLASS="${MVS_MSGCLASS:-H}"
BASE_URL="http://${MVS_HOST}:${MVS_PORT}/zosmf/restjobs/jobs"

# --- All known load modules ---
ALL_MODULES="ABEND0C1 HELLO HTTPD HTTPDM HTTPDMTT HTTPDSL HTTPDSRV HTTPJES2 HTTPLUA HTTPLUAX HTTPREXX HTTPSAY HTTPTEST"

# --- LUA370 library members (all 31) ---
LUA_MEMBERS="LAPI LAUXLIB LBASELIB LCODE LCOROLIB LDBLIB LDEBUG LDO LDUMP LFUNC LGC LINIT LIOLIB LLEX LMATHLIB LMEM LOADLIB LOBJECT LOPCODES LOSLIB LPARSER LSTATE LSTRING LSTRLIB LTABLE LTABLIB LTM LUNDUMP LUTF8LIB LVM LZIO"

# --- Argument parsing ---
if [[ $# -eq 0 ]]; then
  echo "mvslink: usage: mvslink MODULE [MODULE ...] | --all" >&2
  echo "" >&2
  echo "  Available modules: $ALL_MODULES" >&2
  echo "  --all     link all modules" >&2
  exit 1
fi

if [[ "$1" == "--all" ]]; then
  MODULES=($ALL_MODULES)
else
  MODULES=("$@")
fi

# --- Per-module JCL generation ---
#
# Each module gets its own SYSLIB concatenation and NCALIB DD layout,
# matching Rayborn's original link JCLs.
#
# Pattern for most CGI modules:
#   SYSLIB: CRENT370 + HTTPD.NCALIB (auto-resolution)
#   NCALIB: HTTPD.NCALIB (explicit INCLUDEs)
#   INCLUDE SYSLIB(@@CRT1), INCLUDE NCALIB(CGISTART), INCLUDE NCALIB(mod)
#
# HTTPD (main server) is special: HTTPD.NCALIB first in SYSLIB,
#   plus UFS/MQTT, and Lua members explicitly included.
#
# HTTPLUAX: no @@CRT1, no CGISTART, entry is module name,
#   NCALIB includes LUA370.NCALIB for Lua members.
#
# HTTPSAY: uses @@CRTM instead of @@CRT1, no CGISTART.

gen_syslib() {
  local MOD="$1"
  case "$MOD" in
    HTTPD)
      # Main server: HTTPD first, then UFS, CRENT, MQTT
      echo "//SYSLIB   DD DISP=SHR,DSN=${HTTPD_SYSLMOD},DCB=BLKSIZE=32760"
      echo "//         DD DISP=SHR,DSN=${UFS_NCALIB}"
      echo "//         DD DISP=SHR,DSN=${CRENT_NCALIB}"
      echo "//         DD DISP=SHR,DSN=${MQTT_NCALIB}"
      ;;
    HTTPLUA)
      # Lua CGI: needs UFS + MQTT for auto-resolution
      echo "//SYSLIB   DD DISP=SHR,DSN=${CRENT_NCALIB},DCB=BLKSIZE=32760"
      echo "//         DD DISP=SHR,DSN=${UFS_NCALIB}"
      echo "//         DD DISP=SHR,DSN=${HTTPD_SYSLMOD}"
      echo "//         DD DISP=SHR,DSN=${MQTT_NCALIB}"
      ;;
    HTTPLUAX)
      # Lua extension: CRENT + UFS + HTTPD
      echo "//SYSLIB   DD DISP=SHR,DSN=${CRENT_NCALIB},DCB=BLKSIZE=32760"
      echo "//         DD DISP=SHR,DSN=${UFS_NCALIB}"
      echo "//         DD DISP=SHR,DSN=${HTTPD_SYSLMOD}"
      ;;
    *)
      # All other CGI modules: CRENT first, then HTTPD
      echo "//SYSLIB   DD DISP=SHR,DSN=${CRENT_NCALIB},DCB=BLKSIZE=32760"
      echo "//         DD DISP=SHR,DSN=${HTTPD_SYSLMOD}"
      ;;
  esac
}

gen_ncalib() {
  local MOD="$1"
  case "$MOD" in
    HTTPD)
      # Main server: HTTPD + LUA + MQTT
      echo "//NCALIB   DD DISP=SHR,DSN=${HTTPD_SYSLMOD}"
      echo "//         DD DISP=SHR,DSN=${LUA_NCALIB}"
      echo "//         DD DISP=SHR,DSN=${MQTT_NCALIB}"
      ;;
    HTTPLUA)
      # Lua CGI: HTTPD + MQTT
      echo "//NCALIB   DD DISP=SHR,DSN=${HTTPD_SYSLMOD}"
      echo "//         DD DISP=SHR,DSN=${MQTT_NCALIB}"
      ;;
    HTTPLUAX)
      # Lua extension: HTTPD + LUA
      echo "//NCALIB   DD DISP=SHR,DSN=${HTTPD_SYSLMOD},DCB=BLKSIZE=32760"
      echo "//         DD DISP=SHR,DSN=${LUA_NCALIB}"
      ;;
    *)
      # All other modules: just HTTPD
      echo "//NCALIB   DD DISP=SHR,DSN=${HTTPD_SYSLMOD}"
      ;;
  esac
}

gen_includes() {
  local MOD="$1"
  case "$MOD" in
    HTTPD)
      # Main server: @@CRT1, HTTPSTRT, HTTPD, all Lua members, SETCODE AC(1)
      echo "  INCLUDE SYSLIB(@@CRT1)"
      echo "  INCLUDE NCALIB(HTTPSTRT)"
      echo "  INCLUDE NCALIB(HTTPD)"
      for m in $LUA_MEMBERS; do
        echo "  INCLUDE NCALIB(${m})"
      done
      echo "  SETCODE AC(1)"
      ;;
    HTTPLUAX)
      # Lua extension: no CRT, just module + all Lua members
      echo "  INCLUDE NCALIB(HTTPLUAX)"
      for m in $LUA_MEMBERS; do
        echo "  INCLUDE NCALIB(${m})"
      done
      ;;
    HTTPSAY)
      # BREXX helper: uses @@CRTM, no CGISTART
      echo "  INCLUDE SYSLIB(@@CRTM)"
      echo "  INCLUDE NCALIB(HTTPSAY)"
      ;;
    *)
      # Standard CGI module: @@CRT1 + CGISTART + module
      echo "  INCLUDE SYSLIB(@@CRT1)"
      echo "  INCLUDE NCALIB(CGISTART)"
      echo "  INCLUDE NCALIB(${MOD})"
      ;;
  esac
}

gen_entry() {
  local MOD="$1"
  case "$MOD" in
    HTTPLUAX)
      echo "HTTPLUAX"
      ;;
    *)
      echo "@@CRT0"
      ;;
  esac
}

gen_size() {
  local MOD="$1"
  case "$MOD" in
    HTTPD|HTTPLUAX)
      # Large modules need bigger SIZE
      echo "SIZE=(4000K,40K),"
      ;;
    *)
      echo ""
      ;;
  esac
}

# --- Link one module ---
link_module() {
  local MOD="$1"
  local JOBNAME="LKD$(echo "$MOD" | cut -c1-5)"
  JOBNAME="${JOBNAME:0:8}"

  local SIZE
  SIZE=$(gen_size "$MOD")
  local MOD_ENTRY
  MOD_ENTRY=$(gen_entry "$MOD")
  local SYSLIB
  SYSLIB=$(gen_syslib "$MOD")
  local NCALIB
  NCALIB=$(gen_ncalib "$MOD")
  local INCLUDES
  INCLUDES=$(gen_includes "$MOD")

  # Generate JCL
  local TEMPFILE
  TEMPFILE=$(mktemp)
  trap 'rm -f "$TEMPFILE"' RETURN

  cat > "$TEMPFILE" <<ENDJCL
//${JOBNAME} JOB CLASS=${JOBCLASS},REGION=0K,MSGCLASS=${MSGCLASS},
//            MSGLEVEL=(1,1),NOTIFY=DUMMY
//*
//LINK     EXEC PGM=IEWL,PARM='${SIZE}LIST,MAP,XREF,RENT'
//SYSPRINT DD SYSOUT=*
${SYSLIB}
//SYSLMOD  DD DISP=SHR,DSN=${HTTPD_LOADLIB}
//SYSUT1   DD UNIT=SYSALLDA,SPACE=(CYL,(2,1))
${NCALIB}
//SYSLIN   DD DDNAME=SYSIN
//SYSIN    DD *
${INCLUDES}
  ENTRY ${MOD_ENTRY}
  NAME ${MOD}(R)
/*
//*
ENDJCL

  # Strip CR
  sed 's/\r$//' "$TEMPFILE" > "${TEMPFILE}.tmp" && mv "${TEMPFILE}.tmp" "$TEMPFILE"

  # Submit
  local RESULT
  RESULT=$(curl -s -S --connect-timeout 10 --max-time 60 -X PUT \
    -u "${MVS_USER}:${MVS_PASS}" \
    -H "Content-Type: text/plain" \
    -H "X-IBM-Intrdr-Mode: TEXT" \
    -H "X-IBM-Intrdr-Lrecl: 80" \
    -H "X-IBM-Intrdr-Recfm: F" \
    --data-binary @"$TEMPFILE" \
    "$BASE_URL" 2>&1) || {
    echo "mvslink: $MOD — connection failed" >&2
    return 1
  }

  local JOBID
  JOBID=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('jobid',''))" 2>/dev/null) || true
  local RETCODE
  RETCODE=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('retcode',''))" 2>/dev/null) || true

  if [[ -z "$JOBID" ]]; then
    echo "mvslink: $MOD — submit failed" >&2
    echo "$RESULT" >&2
    return 1
  fi

  # Poll for completion
  while [[ -z "$RETCODE" || "$RETCODE" == "None" || "$RETCODE" == "null" ]]; do
    sleep 2
    local STATUS
    STATUS=$(curl -s --connect-timeout 10 --max-time 30 \
      -u "${MVS_USER}:${MVS_PASS}" "$BASE_URL/$JOBNAME/$JOBID" 2>&1)
    RETCODE=$(echo "$STATUS" | python3 -c "import sys,json; print(json.load(sys.stdin).get('retcode',''))" 2>/dev/null) || true
  done

  # Evaluate return code
  local RC_NUM
  RC_NUM=$(echo "$RETCODE" | grep -oE '[0-9]+' | head -1)
  RC_NUM=$((10#${RC_NUM:-9999}))

  if [[ "$RC_NUM" -gt 4 ]]; then
    echo "mvslink: $MOD ($JOBID) FAILED $RETCODE" >&2
    return 1
  fi

  echo "mvslink: $MOD ($JOBID) $RETCODE"
  return 0
}

# --- Main ---
ERRORS=0
for MOD in "${MODULES[@]}"; do
  link_module "$MOD" || ERRORS=$((ERRORS + 1))
done

if [[ "$ERRORS" -gt 0 ]]; then
  echo "mvslink: $ERRORS module(s) failed" >&2
  exit 1
fi

exit 0
