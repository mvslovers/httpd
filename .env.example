# --- mbt build system ---

# MVS connection
MBT_MVS_HOST=mvs
MBT_MVS_PORT=1080
MBT_MVS_USER=IBMUSER
MBT_MVS_PASS=sys1
MBT_MVS_HLQ=IBMUSER
MBT_MVS_DEPS_HLQ=IBMUSER.DEPS

# JES settings
MBT_JES_JOBCLASS=A
MBT_JES_MSGCLASS=H

# Uncomment for MVS/CE systems without public volumes
# MBT_MVS_DEPS_VOLUME=PUB000

# --- Legacy build system (config.mk / scripts/) ---

# MVS host connection
MVS_HOST=localhost
MVS_PORT=1080
MVS_USER=IBMUSER
MVS_PASS=secret

# JES job settings
MVS_JOBCLASS=A
MVS_MSGCLASS=H

# CRENT370 (dependency)
CRENT_MACLIB=CRENT370.MACLIB

# HTTPD datasets
HTTPD_PUNCH=IBMUSER.HTTPD.OBJECT
HTTPD_SYSLMOD=IBMUSER.HTTPD.NCALIB
HTTPD_LOADLIB=IBMUSER.HTTPD.LOAD

# Dependency NCALIBs (for link step)
CRENT_NCALIB=CRENT370.NCALIB
UFS_NCALIB=UFS370.NCALIB
LUA_NCALIB=LUA370.NCALIB
MQTT_NCALIB=MQTT370.NCALIB
